<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <enum id="org.gnome.shell.extensions.claude-usage.box">
    <value nick="left" value="0"/>
    <value nick="center" value="1"/>
    <value nick="right" value="2"/>
  </enum>
  <schema id="org.gnome.shell.extensions.claude-usage"
          path="/org/gnome/shell/extensions/claude-usage/">
    <key name="panel-box" enum="org.gnome.shell.extensions.claude-usage.box">
      <default>'right'</default>
      <summary>Top-bar box</summary>
      <description>Which section of the top bar to place the indicator in.</description>
    </key>
    <key name="panel-position" type="i">
      <default>0</default>
      <range min="0" max="20"/>
      <summary>Position within the box</summary>
      <description>Index within the chosen box (0 = first/closest to the edge for left, to centre for right).</description>
    </key>
  </schema>
</schemalist>
